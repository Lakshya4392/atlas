generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(cuid())
  name            String
  email           String         @unique
  style           String         @default("Smart Casual")
  streak          Int            @default(0)
  level           String         @default("Style Explorer")
  createdAt       DateTime       @default(now())
  preferredBrands String[]       @default([])
  hearSource      String?
  occupation      String?
  wearPreference  String?
  password        String?
  avatar          String?
  bodyMasks       Json?
  digitalTwinUrl  String?
  poseKeypoints   Json?
  clothes         ClothingItem[]
  outfits         Outfit[]
}

model ClothingItem {
  id                  String       @id @default(cuid())
  name                String
  category            String
  color               String
  brand               String
  imageUrl            String
  tags                String[]
  wearCount           Int          @default(0)
  favorite            Boolean      @default(false)
  lastWorn            DateTime?
  userId              String
  fitType             String?
  layerPriority       Int?
  pHash               String?
  sleeveType          String?
  transparentImageUrl String?
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfitItems         OutfitItem[]
}

model Outfit {
  id          String       @id @default(cuid())
  name        String
  occasion    String
  rating      Int          @default(0)
  aiGenerated Boolean      @default(false)
  weather     String?
  date        DateTime     @default(now())
  userId      String
  imageUrl    String?
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       OutfitItem[]
}

model OutfitItem {
  id             String       @id @default(cuid())
  outfitId       String
  clothingItemId String
  clothingItem   ClothingItem @relation(fields: [clothingItemId], references: [id], onDelete: Cascade)
  outfit         Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)

  @@unique([outfitId, clothingItemId])
}

model CachedProduct {
  id          String   @id @default(cuid())
  title       String
  brand       String
  price       String
  thumbnail   String
  link        String
  source      String
  query       String
  createdAt   DateTime @default(now())
  
  category    String?
  subcategory String?
  gender      String?
  color       String?
  material    String?
  style       String?
  metadata    Json?

  @@index([query])
  @@index([category])
  @@index([gender])
}
